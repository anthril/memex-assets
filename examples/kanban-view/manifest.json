{
  "$schema": "../../manifest.schema.json",
  "id": "kanban-view",
  "name": "Kanban View",
  "version": "0.1.0",
  "author": {
    "name": "Anthril",
    "url": "https://anthril.com.au"
  },
  "description": "Renders any section as a kanban board, columnising pages by their `status` frontmatter (To Do / In Progress / Done). Drag a card to update its status.",
  "type": "extension",
  "extensionType": "view",
  "entryPoints": {
    "view": "views/kanban.view.json"
  },
  "permissions": [
    "frontmatter:write",
    "navigation",
    "view"
  ],
  "minimumMemexVersion": "0.2.0",
  "compatibleProfiles": ["*"],
  "tags": ["view", "kanban", "tasks"]
}

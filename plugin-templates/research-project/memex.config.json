{
  "$schema": "https://raw.githubusercontent.com/anthril/memex/main/crates/memex-core/schemas/memex.config.schema.json",
  "version": "1",
  "profile": "research-project",
  "root": ".memex",

  "allowedTopLevel": [
    "README.md",
    "AGENTS.md",
    "index.md",
    "log.md",
    ".open-questions",
    ".rules",
    ".state",
    "raw",
    "wiki",
    "research",
    "architecture",
    "systems",
    "evaluation"
  ],

  "datedFolders": {
    "paths": [],
    "format": "DDMMYYYY-HHMM"
  },

  "readmeRequired": [
    "wiki/entities/*",
    "wiki/concepts/*",
    "research/experiments/*",
    "architecture/*",
    "systems/*",
    "evaluation/*"
  ],

  "frontmatter": {
    "appliesTo": ["**/README.md", "**/AGENTS.md", "wiki/**/*.md", "research/**/*.md", "architecture/**/*.md", "systems/**/*.md", "evaluation/**/*.md"],
    "required": ["title", "slug", "type", "status", "created", "updated"],
    "enum": {
      "type": [
        "entity",
        "concept",
        "summary",
        "analysis",
        "synthesis",
        "hypothesis",
        "methodology",
        "literature-review",
        "experiment",
        "prompt",
        "architecture",
        "system",
        "evaluation",
        "open-question",
        "rule"
      ],
      "status": ["draft", "active", "deprecated"]
    }
  },

  "naming": {
    "exceptions": ["README.md", "AGENTS.md", "CHANGELOG.md", "ROADMAP.md", ".resolved"]
  },

  "codeToDocMapping": [],

  "log": {
    "path": "log.md",
    "entryPrefix": "## [{date}] {event} | {subject}"
  },

  "index": {
    "path": "index.md",
    "sections": [
      "Entities",
      "Concepts",
      "Summaries",
      "Analyses",
      "Syntheses",
      "Hypotheses",
      "Experiments",
      "Architecture",
      "Systems",
      "Evaluation",
      "Open Questions",
      "Recent Activity"
    ]
  },

  "search": {
    "engine": "grep",
    "maxContextPages": 3
  }
}

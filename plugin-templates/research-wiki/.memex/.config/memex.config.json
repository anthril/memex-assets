{
  "$schema": "https://raw.githubusercontent.com/anthril/memex/main/crates/memex-core/schemas/memex.config.schema.json",
  "version": "1",
  "profile": "research-wiki",
  "root": ".memex",

  "allowedTopLevel": [
    "README.md",
    "AGENTS.md",
    "index.md",
    "log.md",
    ".open-questions",
    ".rules",
    ".state",
    "raw",
    "wiki"
  ],

  "datedFolders": {
    "paths": [],
    "format": "DDMMYYYY-HHMM"
  },

  "readmeRequired": [
    "wiki/entities/*",
    "wiki/concepts/*"
  ],

  "frontmatter": {
    "appliesTo": ["**/README.md", "**/AGENTS.md", "wiki/**/*.md"],
    "required": ["title", "slug", "type", "status", "created", "updated"],
    "enum": {
      "type": ["entity", "concept", "summary", "analysis", "synthesis", "open-question", "rule"],
      "status": ["draft", "active", "deprecated"]
    }
  },

  "naming": {
    "exceptions": ["README.md", "AGENTS.md", "CHANGELOG.md"]
  },

  "codeToDocMapping": [],

  "log": {
    "path": "log.md",
    "entryPrefix": "## [{date}] {event} | {subject}"
  },

  "index": {
    "path": "index.md",
    "sections": [
      "Entities",
      "Concepts",
      "Summaries",
      "Analyses",
      "Syntheses",
      "Open Questions",
      "Recent Activity"
    ]
  },

  "search": {
    "engine": "grep",
    "maxContextPages": 3
  }
}

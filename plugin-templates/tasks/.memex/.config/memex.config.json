{
  "$schema": "https://raw.githubusercontent.com/anthril/memex/main/crates/memex-core/schemas/memex.config.schema.json",
  "version": "1",
  "profile": "tasks",
  "root": ".memex",

  "allowedTopLevel": [
    "README.md",
    "AGENTS.md",
    "index.md",
    "log.md",
    ".open-questions",
    ".rules",
    ".state",
    "tasks",
    "epics",
    "milestones",
    "inbox",
    "archive"
  ],

  "datedFolders": {
    "paths": [],
    "format": "YYYY-MM-DD"
  },

  "readmeRequired": ["epics/*", "milestones/*"],

  "frontmatter": {
    "appliesTo": [
      "**/README.md",
      "**/AGENTS.md",
      "tasks/**/*.md",
      "epics/**/*.md",
      "milestones/**/*.md",
      "inbox/**/*.md",
      "archive/**/*.md"
    ],
    "required": [
      "title",
      "slug",
      "type",
      "status",
      "date",
      "created",
      "updated"
    ],
    "enum": {
      "type": ["task", "epic", "milestone", "bug", "spike", "chore"],
      "status": ["backlog", "planned", "in-progress", "blocked", "in-review", "done"],
      "priority": ["p0", "p1", "p2", "p3"]
    }
  },

  "naming": {
    "exceptions": ["README.md", "AGENTS.md", "CHANGELOG.md"]
  },

  "codeToDocMapping": [],

  "calendarFolders": ["tasks", "milestones"],

  "log": {
    "path": "log.md",
    "entryPrefix": "## [{date}] {event} | {subject}"
  },

  "index": {
    "path": "index.md",
    "sections": [
      "Active",
      "Backlog",
      "In Review",
      "Blocked",
      "Recently Done",
      "Epics",
      "Milestones",
      "Inbox",
      "Open Questions"
    ]
  },

  "search": {
    "engine": "grep",
    "maxContextPages": 3
  }
}

{
  "$schema": "https://raw.githubusercontent.com/anthril/memex/main/crates/memex-core/schemas/memex.config.schema.json",
  "version": "1",
  "profile": "generic",
  "root": ".memex",

  "allowedTopLevel": [
    "README.md",
    "AGENTS.md",
    "index.md",
    "log.md",
    ".open-questions",
    ".rules",
    ".state",
    "topics"
  ],

  "datedFolders": {
    "paths": [],
    "format": "DDMMYYYY-HHMM"
  },

  "readmeRequired": ["topics/*"],

  "frontmatter": {
    "appliesTo": ["**/README.md", "**/AGENTS.md"],
    "required": ["title", "slug", "type", "status", "created", "updated"],
    "enum": {
      "type": ["topic", "open-question", "rule"],
      "status": ["draft", "active", "deprecated"]
    }
  },

  "naming": {
    "exceptions": ["README.md", "AGENTS.md", "CHANGELOG.md"]
  },

  "codeToDocMapping": [],

  "log": {
    "path": "log.md",
    "entryPrefix": "## [{date}] {event} | {subject}"
  },

  "index": {
    "path": "index.md",
    "sections": ["Topics", "Open Questions", "Recent Activity"]
  },

  "search": {
    "engine": "grep",
    "maxContextPages": 3
  }
}

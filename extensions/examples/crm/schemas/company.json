{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memex://schemas/crm/company",
  "title": "Company",
  "description": "An organisation you do business with.",
  "type": "object",
  "required": ["name"],
  "additionalProperties": true,
  "properties": {
    "kind": {
      "const": "company"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "size": {
      "type": "string",
      "enum": ["1-10", "11-50", "51-200", "201-1000", "1000+"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
